APP_ENV=production

MYSQL_DATABASE=accounting
MYSQL_USER=accounting
MYSQL_PASSWORD=change-me-database-password
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DSN=accounting:change-me-database-password@tcp(mysql:3306)/accounting?parseTime=true&charset=utf8mb4&loc=UTC

JWT_ACCESS_SECRET=change-me-long-random-access-secret
JWT_REFRESH_SECRET=change-me-long-random-refresh-secret
# 32 random bytes, base64 encoded. Example: openssl rand -base64 32
MFA_ENCRYPTION_KEY=change-me-base64-32-byte-mfa-key

EMAIL_DELIVERY_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
PASSWORD_RESET_BASE_URL=http://localhost:3000/reset-password
INVITATION_BASE_URL=http://localhost:3000/login
EXPOSE_PASSWORD_RESET_TOKEN=false
SELF_SERVICE_REGISTRATION_ENABLED=false

SWAGGER_ENABLED=false
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
LOG_FORMAT=json
LOG_LEVEL=info
METRICS_ENABLED=true

API_PORT=8080
WEB_PORT=3000
MYSQL_PORT=3306

BACKUP_RETENTION_COUNT=14
WORKER_INTERVAL_SECONDS=3600
MARKET_DATA_IMPORT_ENABLED=false
MARKET_DATA_IMPORT_PATH=/app/storage/market-data/amfi.txt
MARKET_DATA_IMPORT_URL=
MARKET_DATA_BEARER_TOKEN=
MARKET_DATA_TIMEOUT_SECONDS=30
# Supported: amfi, csv, nse_equity_csv, yahoo_finance_csv
MARKET_DATA_IMPORT_FORMAT=amfi
MARKET_DATA_SYMBOL_MODE=scheme_code
MARKET_DATA_SOURCE=scheduled_market_data
MARKET_DATA_SYMBOL=
MARKET_DATA_ORGANIZATION_ID=
